# PostgreSQL (this service's own sessions/messages DB, started by ./docker-compose.yml
# on host port 5433 to avoid colliding with the Java BE's shared postgres on 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ai_stylist
POSTGRES_USER=stylist
POSTGRES_PASSWORD=stylist123

# Neo4j (real Java BE stack's shared container, see BE/docker-compose.infra.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Firecrawl blog ingestion
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
FIRECRAWL_TIMEOUT=120

# Concept semantic search (cosine similarity threshold, 0–1)
CONCEPT_SIMILARITY_THRESHOLD=0.65

# Qdrant (real Java BE stack's shared container, see BE/docker-compose.infra.yml)
QDRANT_URL=http://localhost:6333
QDRANT_CONCEPT_COLLECTION=ai_stylist_concepts
QDRANT_PRODUCT_COLLECTION=ai_stylist_products

# Product Service (external; Java product-service, default local port 8083)
PRODUCT_SERVICE_BASE_URL=http://localhost:8083
PRODUCT_SERVICE_TIMEOUT=10

# App
APP_ENV=development
LOG_LEVEL=INFO
